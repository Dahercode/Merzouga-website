---
import { Container } from "@components/odyssey-theme";
import HomeTourSlider from "@components/tours/HomeTourSlider.astro";
import Layout from "../layouts/Page.astro";
import HomeHeroSection from "../components/sections/heros/HomeHeroSection.astro";
import ReassuranceSection from "../components/sections/home/ReassuranceSection.astro";
import i18next, { changeLanguage } from "i18next";
import { getTours } from "../utils/tours";

changeLanguage("en");

const locale = i18next.resolvedLanguage;
const tours = getTours(locale);
---

<Layout>
  <script>
   import "../components/theme-switcher/theme-switcher.ts";
  </script>
  <HomeHeroSection/>
  <ReassuranceSection locale={locale} />
  <Container>
    <HomeTourSlider {tours} {locale} />
  </Container>
</Layout>
