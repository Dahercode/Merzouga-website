---
import { t } from 'i18next';
import ToursPreview from './ToursPreview.astro';

const { tours } = Astro.props;

const cityFilters = [
  { value: 'all',        label: t('tours:filters.all') },
  { value: 'marrakech',  label: t('tours:filters.cities.marrakech') },
  { value: 'fes',        label: t('tours:filters.cities.fes') },
  { value: 'casablanca', label: t('tours:filters.cities.casablanca') },
];

const nightFilters = [
  { value: 'all', label: t('tours:filters.all') },
  { value: '1-2', label: t('tours:filters.nights.1-2') },
  { value: '3-4', label: t('tours:filters.nights.3-4') },
  { value: '5-7', label: t('tours:filters.nights.5-7') },
  { value: '8+',  label: t('tours:filters.nights.8+') },
];

const totalCount = tours?.length || 0;
const noResultsMsg = t('tours:filters.noResults');
// Interpolated strings for the server-side static render
const resultsMsg = t('tours:filters.results', { count: totalCount });
const resultsMsgPlural = t('tours:filters.results_plural', { count: totalCount });
// Raw templates stored in data attributes so JS can replace {{count}} with the live count
const msgTemplate = t('tours:filters.results');
const msgTemplatePlural = t('tours:filters.results_plural');
---

<div class="tours-filter">
  <!-- Filter controls -->
  <div class="tours-filter__controls">
    <div class="tours-filter__group">
      <span class="tours-filter__label">{t('tours:filters.departureFrom')}</span>
      <div class="tours-filter__pills" role="group" aria-label={t('tours:filters.departureFrom')}>
        {cityFilters.map((f, i) => (
          <button
            class={`filter-pill${i === 0 ? ' is-active' : ''}`}
            data-filter="city"
            data-value={f.value}
            type="button"
          >
            {f.label}
          </button>
        ))}
      </div>
    </div>

    <div class="tours-filter__group">
      <span class="tours-filter__label">{t('tours:filters.nightsLabel')}</span>
      <div class="tours-filter__pills" role="group" aria-label={t('tours:filters.nightsLabel')}>
        {nightFilters.map((f, i) => (
          <button
            class={`filter-pill${i === 0 ? ' is-active' : ''}`}
            data-filter="nights"
            data-value={f.value}
            type="button"
          >
            {f.label}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- Results count -->
  <p
    class="tours-filter__count"
    id="tours-count"
    aria-live="polite"
    data-msg={msgTemplate}
    data-msg-plural={msgTemplatePlural}
  >
    {totalCount === 1 ? resultsMsg : resultsMsgPlural}
  </p>

  <!-- Tour grid -->
  <ul class="tours-list__list" id="tours-grid">
    {tours?.map((tour) => <ToursPreview tour={tour} />)}
  </ul>

  <!-- Empty state: hidden by CSS default, shown via JS style.display -->
  <div class="tours-filter__empty" id="tours-empty">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <circle cx="11" cy="11" r="8" />
      <path d="M21 21l-4.35-4.35" />
    </svg>
    <p>{noResultsMsg}</p>
  </div>
</div>

<script>
  const grid = document.getElementById('tours-grid');
  const emptyEl = document.getElementById('tours-empty') as HTMLElement | null;
  const countEl = document.getElementById('tours-count') as HTMLElement | null;

  if (grid && emptyEl && countEl) {
    const allCards = Array.from(grid.querySelectorAll<HTMLElement>('li[data-city]'));
    const msgSingular = countEl.dataset.msg || '';
    const msgPlural = countEl.dataset.msgPlural || '';

    let activeCity = 'all';
    let activeNights = 'all';

    function nightsInRange(n: number, filter: string): boolean {
      if (filter === 'all') return true;
      if (filter === '1-2') return n >= 1 && n <= 2;
      if (filter === '3-4') return n >= 3 && n <= 4;
      if (filter === '5-7') return n >= 5 && n <= 7;
      if (filter === '8+')  return n >= 8;
      return true;
    }

    function applyFilters() {
      let visible = 0;

      allCards.forEach((card) => {
        const city = card.dataset.city || '';
        const nights = parseInt(card.dataset.nights || '0', 10);
        const show =
          (activeCity === 'all' || city === activeCity) &&
          nightsInRange(nights, activeNights);

        // Use style.display — avoids CSS specificity conflicts with [hidden]
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      const msg = visible === 1 ? msgSingular : msgPlural;
      countEl.textContent = msg.replace('{{count}}', String(visible));

      // Show/hide empty state via inline style (bypasses scoped CSS conflict)
      emptyEl.style.display = visible === 0 ? 'flex' : 'none';
    }

    document.querySelectorAll<HTMLElement>('.filter-pill').forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        const value = btn.dataset.value || 'all';

        const group = btn.closest('.tours-filter__pills');
        if (group) {
          group.querySelectorAll('.filter-pill').forEach((b) => b.classList.remove('is-active'));
        }
        btn.classList.add('is-active');

        if (filter === 'city') activeCity = value;
        if (filter === 'nights') activeNights = value;

        applyFilters();
      });
    });

    // Run once on load to set correct initial count
    applyFilters();
  }
</script>

<style>
  /* ── Filter Controls ── */
  .tours-filter__controls {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--theme-bg-offset, rgba(0, 0, 0, 0.04));
    border-radius: var(--theme-shape-radius);
    border: 1px solid var(--theme-border, rgba(0, 0, 0, 0.08));
  }

  .tours-filter__group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .tours-filter__label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--theme-text-light, #888);
    white-space: nowrap;
    min-width: 7rem;
  }

  .tours-filter__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* ── Pills ── */
  .filter-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 1rem;
    border-radius: 2rem;
    border: 1.5px solid var(--theme-primary);
    background: transparent;
    color: var(--theme-primary);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition:
      background 0.18s,
      color 0.18s,
      border-color 0.18s,
      box-shadow 0.18s;
    line-height: 1;
  }

  .filter-pill:hover {
    background: var(--theme-primary);
    color: var(--theme-on-primary, #fff);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .filter-pill.is-active {
    background: var(--theme-primary);
    color: var(--theme-on-primary, #fff);
    border-color: var(--theme-primary);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  /* ── Results Count ── */
  .tours-filter__count {
    font-size: 0.875rem;
    color: var(--theme-text-light, #888);
    margin: 0 0 1rem 0;
  }

  /* ── Tour Grid ── */
  .tours-list__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  /* ── Empty State: hidden by default, JS sets style.display to show ── */
  .tours-filter__empty {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 3rem 1rem;
    color: var(--theme-text-light, #888);
    text-align: center;
  }

  .tours-filter__empty svg {
    width: 3rem;
    height: 3rem;
    opacity: 0.4;
  }

  .tours-filter__empty p {
    margin: 0;
    font-size: 0.95rem;
    max-width: 28rem;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .tours-list__list {
      grid-template-columns: 1fr;
    }

    .tours-filter__controls {
      padding: 1rem;
    }

    .tours-filter__group {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .tours-filter__label {
      min-width: unset;
    }
  }

  @media (max-width: 480px) {
    .filter-pill {
      font-size: 0.8rem;
      padding: 0.35rem 0.8rem;
    }
  }
</style>
