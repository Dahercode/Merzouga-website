---
import { Image } from 'astro:assets';
import { t } from 'i18next';

const { tour } = Astro.props;

// Extract city from href slug (e.g. /tours/posts/marrakech-3-days-merzouga → marrakech)
const slugPart = tour.href?.split('/').pop() || '';
const dataCity = slugPart.split('-')[0] || 'other';

// Extract nights from duration string by taking the number after "/"
// Works for any language: "3 days / 2 nights", "7 jours / 6 nuits", "7 días / 6 noches"
const nightsPart = (tour.duration || '').split('/')[1] || '';
const dataNights = parseInt(nightsPart.trim(), 10) || 0;
---

<li class="tour__preview" data-city={dataCity} data-nights={dataNights}>
  <a href={tour.href}>
    <div class="tour__preview-image-wrapper">
      <Image
        src={tour.featuredImage}
        alt={tour.title}
        width={600}
        height={400}
        loading="lazy"
      />
      {tour.duration && (
        <span class="tour__preview-duration">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
            <path d="M16 2v4M8 2v4M3 10h18" />
          </svg>
          <span>{tour.duration}</span>
        </span>
      )}
      {tour.price && (
        <span class="tour__preview-price">
          {/* TODO: replace t('tours:priceOnRequest') with {tour.price} when prices are set */}
          {t('tours:priceOnRequest')}
        </span>
      )}
    </div>
    <h3>{tour.title}</h3>
    {tour.excerpt && <p>{tour.excerpt}</p>}
  </a>
</li>

<style>
  .tour__preview-image-wrapper {
    position: relative;
    margin-bottom: 1rem;
  }

  .tour__preview img {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: calc(var(--theme-shape-radius) / 2);
    transition: border-radius var(--theme-transition);
  }

  .tour__preview:hover img {
    border-radius: var(--theme-shape-radius);
  }

  .tour__preview-price {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    /* Amber warm: signals bespoke/on-request, not a fixed price */
    /* TODO: switch back to var(--theme-primary) when real prices are set */
    background: rgba(160, 105, 20, 0.88);
    color: #fff;
    padding: 0.4rem 0.85rem;
    border-radius: calc(var(--theme-shape-radius) / 2);
    font-size: 0.85rem;
    font-weight: 500;
    font-style: italic;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    backdrop-filter: blur(4px);
  }

  .tour__preview-duration {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.7rem;
    background: rgba(0, 0, 0, 0.7);
    color: white;
    border-radius: calc(var(--theme-shape-radius) / 2);
    font-size: 0.8rem;
    font-weight: 500;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    backdrop-filter: blur(4px);
  }

  .tour__preview-duration svg {
    width: 14px;
    height: 14px;
  }

  @media (max-width: 480px) {
    .tour__preview-price,
    .tour__preview-duration {
      font-size: 0.75rem;
      padding: 0.35rem 0.6rem;
    }
    .tour__preview-duration svg {
      width: 12px;
      height: 12px;
    }
  }

  .tour__preview a {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .tour__preview h3,
  .tour__preview h4 {
    margin: 0;
  }
</style>
