---
const { included = [], excluded = [] } = Astro.props;
---

<div class="tour-inclusions">
  <div class="tour-inclusions__grid">
    <div class="tour-inclusions__column tour-inclusions__column--included">
      <h3 class="tour-inclusions__heading">
        What's Included
      </h3>
      <ul class="tour-inclusions__list">
        {included.map((item) => (
          <li class="tour-inclusions__item tour-inclusions__item--included">
            <svg class="tour-inclusions__icon" viewBox="0 0 24 24" fill="currentColor">
              <circle cx="12" cy="12" r="9" opacity="0.2" />
              <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" fill="none" />
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="tour-inclusions__column tour-inclusions__column--excluded">
      <h3 class="tour-inclusions__heading">
        Not Included
      </h3>
      <ul class="tour-inclusions__list">
        {excluded.map((item) => (
          <li class="tour-inclusions__item tour-inclusions__item--excluded">
            <svg class="tour-inclusions__icon" viewBox="0 0 24 24" fill="currentColor">
              <circle cx="12" cy="12" r="9" opacity="0.15" />
              <path d="M15 9l-6 6m0-6l6 6" stroke="currentColor" stroke-width="2" fill="none" />
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>

<style>
  .tour-inclusions {
    margin: 2rem 0;
  }

  .tour-inclusions__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .tour-inclusions__column {
    padding: 1.5rem;
    border-radius: var(--theme-shape-radius);
    border: 2px solid;
  }

  .tour-inclusions__column--included {
    background: linear-gradient(135deg,
      color-mix(in srgb, #10b981 5%, var(--theme-surface-1)),
      var(--theme-surface-1));
    border-color: #10b981;
  }

  .tour-inclusions__column--excluded {
    background: linear-gradient(135deg,
      color-mix(in srgb, #ef4444 5%, var(--theme-surface-1)),
      var(--theme-surface-1));
    border-color: #ef4444;
  }

  .tour-inclusions__heading {
    margin: 0 0 1.25rem 0;
    font-size: 1.15rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .tour-inclusions__column--included .tour-inclusions__heading {
    color: #059669;
  }

  .tour-inclusions__column--excluded .tour-inclusions__heading {
    color: #dc2626;
  }

  .tour-inclusions__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .tour-inclusions__item {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    line-height: 1.5;
  }

  .tour-inclusions__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .tour-inclusions__item--included .tour-inclusions__icon {
    color: #10b981;
  }

  .tour-inclusions__item--excluded .tour-inclusions__icon {
    color: #ef4444;
  }

  @media (max-width: 768px) {
    .tour-inclusions__grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
