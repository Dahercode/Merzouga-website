---
const { highlights = [] } = Astro.props;
---

<div class="tour-highlights">
  <ul class="tour-highlights__list">
    {highlights.map((highlight) => (
      <li class="tour-highlights__item">
        <svg class="tour-highlights__icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
        </svg>
        <span>{highlight}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .tour-highlights {
    margin: 2.5rem 0;
  }

  .tour-highlights__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.25rem 2rem;
  }

  .tour-highlights__item {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    line-height: 1.6;
  }

  .tour-highlights__icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    color: var(--theme-primary);
    margin-top: 3px;
  }

  .tour-highlights__item span {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--theme-on-bg);
  }

  @media (max-width: 768px) {
    .tour-highlights__list {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .tour-highlights__item span {
      font-size: 1rem;
    }
  }
</style>
