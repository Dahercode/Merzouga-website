---
import { t } from 'i18next';
import ToursPreview from './ToursPreview.astro';

const { tours, locale } = Astro.props;

const toursPageHref = !locale || locale === 'en' ? '/tours' : `/${locale}/tours`;

const cityLabels: Record<string, string> = {
  marrakech: 'Marrakech',
  fes: 'Fès',
  casablanca: 'Casablanca',
};

const cityOrder = ['marrakech', 'fes', 'casablanca'];

const slides = cityOrder
  .map((city) => ({
    city,
    label: cityLabels[city],
    tours: (tours || []).filter((tour: any) => {
      const slug = (tour.href || '').split('/').pop() || '';
      return slug.split('-')[0] === city;
    }).slice(0, 2),
  }))
  .filter((s) => s.tours.length > 0);
---

<section class="home-slider">
  <div class="home-slider__header">
    <div class="home-slider__titles">
      <h2>{t('home:sections.tours.title')}</h2>
      <p class="home-slider__description">{t('home:sections.tours.description')}</p>
    </div>
    <a href={toursPageHref} class="home-slider__see-more">
      {t('home:sections.tours.seeMore')}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>

  {slides.length > 0 && (
    <div>
      <!-- City tabs -->
      <div class="home-slider__tabs" role="tablist">
        {slides.map(({ label }, i) => (
          <button
            class={`home-slider-tab${i === 0 ? ' is-active' : ''}`}
            data-slide-tab={i}
            type="button"
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            {label}
          </button>
        ))}
      </div>

      <!-- Slider viewport -->
      <div class="home-slider__viewport">
        <div class="home-slider__track" id="home-slider-track">
          {slides.map(({ tours: slideTours }) => (
            <div class="home-slider__slide" role="tabpanel">
              <ul class="home-slider__grid">
                {slideTours.map((tour: any) => <ToursPreview {tour} />)}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}
</section>

<script>
  const track = document.getElementById('home-slider-track') as HTMLElement | null;
  if (track) {
    const tabs = document.querySelectorAll<HTMLElement>('[data-slide-tab]');

    function goTo(index: number) {
      track.style.transform = `translateX(-${index * 100}%)`;
      tabs.forEach((tab, i) => {
        tab.classList.toggle('is-active', i === index);
        tab.setAttribute('aria-selected', i === index ? 'true' : 'false');
      });
    }

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => goTo(i));
    });
  }
</script>

<style>
  .home-slider {
    margin: var(--section-margin, 4rem) auto;
  }

  /* ── Header ── */
  .home-slider__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .home-slider__titles h2 {
    margin: 0 0 0.25rem;
  }

  .home-slider__description {
    margin: 0;
    color: var(--theme-text-light, #888);
    font-size: 1rem;
  }

  /* ── See More link (subtle / watermark style) ── */
  .home-slider__see-more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #6b6b6b; /* WCAG AA on white: ~5.7:1 — was #999 (2.56:1, failing) */
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.35rem;
    transition: color 0.2s;
  }

  .home-slider__see-more:hover {
    color: var(--theme-primary);
  }

  /* ── City Tabs ── */
  .home-slider__tabs {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .home-slider-tab {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 1.1rem;
    border-radius: 2rem;
    border: 1.5px solid var(--theme-primary);
    background: transparent;
    color: var(--theme-primary);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.18s, color 0.18s, box-shadow 0.18s;
    line-height: 1;
  }

  .home-slider-tab:hover,
  .home-slider-tab.is-active {
    background: var(--theme-primary);
    color: var(--theme-on-primary, #fff);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  /* ── Slider ── */
  .home-slider__viewport {
    overflow: hidden;
  }

  .home-slider__track {
    display: flex;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .home-slider__slide {
    flex: 0 0 100%;
    min-width: 0;
  }

  .home-slider__grid {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .home-slider__header {
      flex-direction: row;
      align-items: center;
    }

    .home-slider__titles h2 {
      font-size: 1.4rem;
    }

    .home-slider__description {
      display: none;
    }

    .home-slider__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .home-slider-tab {
      font-size: 0.8rem;
      padding: 0.35rem 0.85rem;
    }

    .home-slider__see-more {
      font-size: 0.8rem;
    }
  }
</style>
